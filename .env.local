## Docker Build
DOCKER_BUILD_ARCH='linux/arm64/v8'

## Main app settings
DOMAIN=https://localhost:8181
PROXY_BACKEND=fastapi
PROXY_PORT=8000

## DB Postgres
DB_CONNECTION=postgresql
DB_HOST=host.docker.internal
DB_PORT=44003
DB_DATABASE=local
DB_USERNAME=root
DB_PASSWORD=root

## Authentication
API_TOKEN=xxx
